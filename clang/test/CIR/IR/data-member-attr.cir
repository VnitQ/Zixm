// RUN: cir-opt %s -split-input-file | FileCheck %s

// -----

!u32i = !cir.int<u, 32>
!rec = !cir.record<struct "S" {!u32i}>

module {
  cir.global external @gv = #cir.data_member<[0]> : !cir.data_member<!u32i in !rec>
  cir.global external @null_gv = #cir.data_member<null>
      : !cir.data_member<!u32i in !rec>
  cir.func @roundtrip() {
    cir.return
  }
}

// CHECK: cir.global external @gv = #cir.data_member<[0]>
// CHECK: cir.global external @null_gv = #cir.data_member<null>

// -----
// Check that a non-zero member index parses and round-trips correctly.

!u16i = !cir.int<u, 16>
!u32i = !cir.int<u, 32>
!rec2 = !cir.record<struct "T" {!u16i, !u32i}>

module {
  cir.global external @second_member = #cir.data_member<[1]>
      : !cir.data_member<!u32i in !rec2>
}

// CHECK: cir.global external @second_member = #cir.data_member<[1]>

// -----
// Check that a multi-element (inherited member) path round-trips correctly.

!u16i = !cir.int<u, 16>
!u32i = !cir.int<u, 32>
!base = !cir.record<struct "Base" {!u16i, !u32i}>
!derived = !cir.record<struct "Derived" {!base}>

module {
  cir.global external @inherited_member = #cir.data_member<[0, 1]>
      : !cir.data_member<!u32i in !derived>
}

// CHECK: cir.global external @inherited_member = #cir.data_member<[0, 1]>
